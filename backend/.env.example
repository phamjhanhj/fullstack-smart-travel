# Google Places (Locations module)
GOOGLE_PLACES_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8100
